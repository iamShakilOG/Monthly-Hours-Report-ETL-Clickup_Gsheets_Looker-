# Google service account JSON file (local path)
GOOGLE_CREDS_FILE=path/to/service_account.json

# Source sheets
PROJECT_SHEET_KEY=your_project_sheet_key
PROJECT_TAB=For Internal Report

INTERNAL_LOG_SHEET_KEY=your_internal_log_sheet_key
INTERNAL_LOG_TAB=Form Responses 1

# ClickUp
CLICKUP_API_TOKEN=your_clickup_token
CLICKUP_LIST_ID=your_clickup_list_id

# Output sheet
OUTPUT_SHEET_URL=https://docs.google.com/spreadsheets/d/your_sheet_id/edit
PROJECT_REPORT_TAB=Project Report
MERGED_REPORT_TAB=Merged

# Logging
LOG_LEVEL=INFO
